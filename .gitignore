# Track only the web viewer package in this repository.
*
!/.gitignore
!/web_viewer/
!/web_viewer/**

# Python runtime artifacts
__pycache__/
*.py[cod]
web_viewer/__pycache__/

# Local generated caches
web_viewer/cache/

# Large generated database
web_viewer/data/expression.sqlite
web_viewer/data/*.sqlite
web_viewer/data/*.sqlite-*

# Local logs and temporary files
*.log
.DS_Store
